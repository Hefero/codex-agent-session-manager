{
  "name": "codex-agent-session-manager",
  "version": "0.1.0-alpha.2",
  "description": "Agent-facing Codex App Server session manager with an MCP validation harness.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apethor/codex-agent-session-manager.git"
  },
  "homepage": "https://github.com/Apethor/codex-agent-session-manager#readme",
  "bugs": {
    "url": "https://github.com/Apethor/codex-agent-session-manager/issues"
  },
  "keywords": [
    "agent-tools",
    "app-server",
    "codex",
    "codex-cli",
    "mcp",
    "model-context-protocol",
    "session-manager"
  ],
  "bin": {
    "codex-agent-session-manager": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/*.cs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "serve": "node --import tsx src/cli.ts serve",
    "remote": "node --import tsx src/cli.ts remote",
    "smoke": "node --import tsx scripts/smoke.ts",
    "security:scan": "node --import tsx scripts/security-scan.ts",
    "security:smoke": "node --import tsx scripts/smoke-security-scan.ts",
    "audit:prod": "npm audit --omit=dev",
    "pack:dry-run": "npm run build && npm pack --dry-run",
    "pack:smoke": "npm run build && node --import tsx scripts/pack-smoke.ts",
    "pack:validate": "npm run pack:smoke && npm run pack:dry-run",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
